{
  "name": "meccg",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:nightly": "npm run test:nightly -w @meccg/shared",
    "lint": "eslint packages/*/src/",
    "lint:fix": "eslint --fix packages/*/src/",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#docs/api' '#.claude'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#docs/api' '#.claude'",
    "build": "tsc --build packages/game-server/tsconfig.json packages/text-client/tsconfig.json packages/lobby-server/tsconfig.json packages/lobby-server/tsconfig.browser.json",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "markdownlint-cli2": "^0.22.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
