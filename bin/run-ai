#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$HOME/.meccg/logs"
LOG_FILE="$LOG_DIR/ai.log"

mkdir -p "$LOG_DIR"

while true; do
  git checkout master 2>&1 | tee -a "$LOG_FILE"
  git pull 2>&1 | tee -a "$LOG_FILE"

  # Check for unhandled requests. Skip feature-requests — those need
  # human review (approve/decline) and cannot be handled by the AI.
  MSG_ID=$("$SCRIPT_DIR/list-requests" | awk '$3 != "feature-request" {print $2; exit}')

  if [ -z "$MSG_ID" ]; then
    echo "=== No pending requests at $(date -Iseconds), sleeping ===" | tee -a "$LOG_FILE"
    sleep 60
    continue
  fi

  echo "=== Handling $MSG_ID at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  "$SCRIPT_DIR/handle-mail" "$MSG_ID" 2>&1 | tee -a "$LOG_FILE"
  echo "=== Finished $MSG_ID at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  sleep 10
done
