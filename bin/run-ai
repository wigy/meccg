#!/bin/bash
set -e

LOG_DIR="$HOME/.meccg/logs"
LOG_FILE="$LOG_DIR/ai.log"

mkdir -p "$LOG_DIR"

while true; do
  git pull 2>&1 | tee -a "$LOG_FILE"
  echo "=== AI run started at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  claude --dangerously-skip-permissions --verbose -p /ai-processor 2>&1 | tee -a "$LOG_FILE"
  echo "=== AI run finished at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  sleep 60
done
