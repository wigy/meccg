#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$HOME/.meccg/logs"
LOG_FILE="$LOG_DIR/ai.log"
RAW_LOG_FILE="$LOG_DIR/ai-raw.log"

mkdir -p "$LOG_DIR"

while true; do
  git pull 2>&1 | tee -a "$LOG_FILE"
  echo "=== AI run started at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  claude --dangerously-skip-permissions --output-format stream-json -p /ai-processor 2>>"$LOG_FILE" \
    | tee -a "$RAW_LOG_FILE" \
    | "$SCRIPT_DIR/stream-filter" \
    | tee -a "$LOG_FILE"
  echo "=== AI run finished at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  sleep 60
done
