#!/bin/bash
set -e

if [ $# -ge 1 ] && { [ "$1" = "-h" ] || [ "$1" = "--help" ]; }; then
  cat <<'EOF'
Usage: bin/run-ai

Long-running worker loop that polls for unhandled ai requests and
dispatches them to bin/handle-mail one at a time. Pulls master between
iterations and skips feature-requests (which require human review).

Environment:
  MECCG_LOBBY_URL   Lobby base URL (default http://localhost:8080)
  MECCG_MASTER_KEY  Lobby master key. Falls back to
                    ~/.meccg/secrets.json when unset.

Options:
  -h, --help      Show this help message.
EOF
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$HOME/.meccg/logs"
LOG_FILE="$LOG_DIR/ai.log"
SECRETS="$HOME/.meccg/secrets.json"
BASE_URL="${MECCG_LOBBY_URL:-http://localhost:8080}"
BASE_URL="${BASE_URL%/}"

mkdir -p "$LOG_DIR"

master_key() {
  if [ -n "${MECCG_MASTER_KEY:-}" ]; then
    echo "$MECCG_MASTER_KEY"
    return 0
  fi
  if [ -f "$SECRETS" ]; then
    jq -r .masterKey "$SECRETS"
    return 0
  fi
  echo "[run-ai] ERROR: no master key (set MECCG_MASTER_KEY or provide $SECRETS)" >&2
  return 1
}

# Fetch unhandled requests from the lobby system API and print the first
# non-feature-request message ID. Feature-requests need human review
# (approve/decline) and cannot be auto-handled.
next_request_id() {
  curl -sf -X GET "$BASE_URL/api/system/ai-requests" \
    -H "Authorization: Bearer $(master_key)" 2>/dev/null \
    | jq -r '[.requests[] | select(.topic != "feature-request")][0].id // empty' 2>/dev/null
}

IDLE_BACKOFF=(60 120 240 480 960 1920 3600)
idle_index=0

while true; do
  # Refuse to keep looping on a dirty tree. A previous skill that
  # ended without committing would otherwise contaminate the next
  # run's branch. Stashing hides the problem — bail instead so the
  # operator has to convert the leftovers into a proper PR (or
  # revert) before restarting.
  cd "$SCRIPT_DIR/.."
  if [ -n "$(git status --porcelain)" ]; then
    echo "=== FATAL: working tree dirty at $(date -Iseconds). Stopping run-ai. ===" | tee -a "$LOG_FILE"
    git status --porcelain | sed 's/^/[run-ai]   /' | tee -a "$LOG_FILE"
    echo "[run-ai] Turn these files into a PR or revert them, then restart run-ai." | tee -a "$LOG_FILE"
    exit 2
  fi

  git checkout master 2>&1 | tee -a "$LOG_FILE"
  git pull 2>&1 | tee -a "$LOG_FILE"

  MSG_ID=$(next_request_id)

  if [ -z "$MSG_ID" ]; then
    delay="${IDLE_BACKOFF[$idle_index]}"
    echo "=== No pending requests at $(date -Iseconds), sleeping ${delay}s ===" | tee -a "$LOG_FILE"
    sleep "$delay"
    if [ "$idle_index" -lt $((${#IDLE_BACKOFF[@]} - 1)) ]; then
      idle_index=$((idle_index + 1))
    fi
    continue
  fi

  idle_index=0
  echo "=== Handling $MSG_ID at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  "$SCRIPT_DIR/handle-mail" "$MSG_ID" 2>&1 | tee -a "$LOG_FILE"
  echo "=== Finished $MSG_ID at $(date -Iseconds) ===" | tee -a "$LOG_FILE"
  echo
  echo
  echo
  sleep 10
done
