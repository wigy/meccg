#!/usr/bin/env bash
# Build the MECCG Docker image and push it to Docker Hub with a given version tag.
#
# Requires:
#   DOCKER_USER     — Docker Hub username
#   DOCKER_PASSWORD — Docker Hub password or access token
#
# Usage: bin/build-and-publish [VERSION]
set -euo pipefail

if [ $# -ge 1 ] && { [ "$1" = "-h" ] || [ "$1" = "--help" ]; }; then
  cat <<'EOF'
Usage: bin/build-and-publish [VERSION]

Build the MECCG Docker image and push it to Docker Hub tagged with VERSION.
If VERSION is not provided as an argument, the script prompts for it.

Arguments:
  VERSION          Tag to publish (e.g. 0.21.0). Prompted if omitted.

Environment:
  DOCKER_USER      Docker Hub username (required)
  DOCKER_PASSWORD  Docker Hub password or access token (required)

Options:
  -h, --help       Show this help message.
EOF
  exit 0
fi

if [ $# -ge 1 ]; then
  VERSION="$1"
else
  read -r -p "Version to publish: " VERSION
fi

if [ -z "${VERSION:-}" ]; then
  echo "Error: VERSION is required." >&2
  exit 1
fi

: "${DOCKER_USER:?DOCKER_USER is not set}"
: "${DOCKER_PASSWORD:?DOCKER_PASSWORD is not set}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
IMAGE="$DOCKER_USER/meccg-dev:$VERSION"

log() { echo "[build-and-publish] $*"; }

cd "$PROJECT_DIR"

log "Logging in to Docker Hub as $DOCKER_USER..."
echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USER" --password-stdin

trap 'docker logout >/dev/null 2>&1 || true' EXIT

log "Building image $IMAGE..."
docker build -f Dockerfile.dev -t "$IMAGE" .

log "Pushing image $IMAGE..."
docker push "$IMAGE"

log "Done."
