#!/usr/bin/env node
/**
 * @module credits
 *
 * List and modify player credit balances directly on disk by reading/writing
 * each account's info.json under ~/.meccg/players/<dirname>/info.json. Every
 * mutation is also recorded as a new entry in the player's credit history
 * file at ~/.meccg/players/<dirname>/credits.json — `bin/credits` is the
 * sole writer of credits, so logging here covers every change (including
 * the deductions that bin/handle-mail performs after request processing).
 *
 * Usage:
 *   bin/credits                                    List all players and their credits
 *   bin/credits add <player> <amount> [<reason>]   Add <amount> credits to <player>
 *   bin/credits set <player> <amount> [<reason>]   Set <player>'s credits to <amount>
 *
 * Mirrors the DEFAULT_CREDITS / getCredits semantics in
 * packages/lobby-server/src/players/store.ts: a missing `credits` field is
 * treated as 0.
 */

import { readFileSync, writeFileSync, readdirSync, statSync, existsSync } from 'fs';
import { join } from 'path';
import { homedir } from 'os';

const PLAYERS_DIR = process.env.PLAYERS_DIR ?? join(homedir(), '.meccg', 'players');
const DEFAULT_CREDITS = 0;

/** Normalize a player name to its directory name (matches store.ts toDirName). */
function toDirName(name) {
  return name.toLowerCase().replace(/[^a-z0-9]/g, '-');
}

/** Read a player's info.json. Returns null if missing or unreadable. */
function readPlayer(dirName) {
  const infoPath = join(PLAYERS_DIR, dirName, 'info.json');
  try {
    return JSON.parse(readFileSync(infoPath, 'utf-8'));
  } catch {
    return null;
  }
}

/** Write a player's info.json back to disk. */
function writePlayer(dirName, record) {
  const infoPath = join(PLAYERS_DIR, dirName, 'info.json');
  writeFileSync(infoPath, JSON.stringify(record, null, 2));
}

/** Path to a player's credit history file. */
function historyPath(dirName) {
  return join(PLAYERS_DIR, dirName, 'credits.json');
}

/** Read a player's credit history. Returns [] if the file doesn't exist or is unreadable. */
function readHistory(dirName) {
  const path = historyPath(dirName);
  if (!existsSync(path)) return [];
  try {
    const parsed = JSON.parse(readFileSync(path, 'utf-8'));
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

/**
 * Append an entry to a player's credit history. The entry records the
 * delta (positive or negative), the resulting balance, an ISO datetime,
 * and a human-readable explanation.
 */
function appendHistory(dirName, delta, balance, explanation) {
  const entries = readHistory(dirName);
  entries.push({
    datetime: new Date().toISOString(),
    amount: delta,
    balance,
    explanation,
  });
  writeFileSync(historyPath(dirName), JSON.stringify(entries, null, 2));
}

/** Find a player by case-insensitive name match. Returns { dirName, record } or null. */
function findPlayer(name) {
  const dirName = toDirName(name);
  const record = readPlayer(dirName);
  if (record) return { dirName, record };
  return null;
}

/** List all player directories that contain an info.json. */
function listAllPlayers() {
  let entries;
  try {
    entries = readdirSync(PLAYERS_DIR);
  } catch {
    return [];
  }
  const players = [];
  for (const entry of entries) {
    const full = join(PLAYERS_DIR, entry);
    try {
      if (!statSync(full).isDirectory()) continue;
    } catch {
      continue;
    }
    const record = readPlayer(entry);
    if (record) players.push({ dirName: entry, record });
  }
  return players;
}

function parseAmount(raw) {
  const n = Number(raw);
  if (!Number.isFinite(n) || !Number.isInteger(n)) {
    console.error(`Error: amount must be an integer, got "${raw}"`);
    process.exit(1);
  }
  return n;
}

function usage() {
  console.error('Usage:');
  console.error('  bin/credits                                    List all players and their credits');
  console.error('  bin/credits add <player> <amount> [<reason>]   Add <amount> credits to <player>');
  console.error('  bin/credits set <player> <amount> [<reason>]   Set <player>\'s credits to <amount>');
  process.exit(1);
}

const args = process.argv.slice(2);
const cmd = args[0];

if (!cmd) {
  // ---- List ----
  const players = listAllPlayers();
  if (players.length === 0) {
    console.log('(no players found)');
    process.exit(0);
  }
  players.sort((a, b) => a.record.name.localeCompare(b.record.name));
  const nameWidth = Math.max(...players.map(p => p.record.name.length), 4);
  console.log(`${'Name'.padEnd(nameWidth)}  Credits`);
  console.log(`${'-'.repeat(nameWidth)}  -------`);
  for (const { record } of players) {
    const credits = record.credits ?? DEFAULT_CREDITS;
    console.log(`${record.name.padEnd(nameWidth)}  ${credits}`);
  }
  process.exit(0);
}

if (cmd === 'add' || cmd === 'set') {
  if (args.length < 3 || args.length > 4) usage();
  const playerName = args[1];
  const amount = parseAmount(args[2]);
  const explanation = args[3] && args[3].trim() ? args[3].trim() : 'manual adjustment';

  const found = findPlayer(playerName);
  if (!found) {
    console.error(`Error: player "${playerName}" not found`);
    process.exit(1);
  }

  const current = found.record.credits ?? DEFAULT_CREDITS;
  const next = cmd === 'add' ? current + amount : amount;
  const delta = next - current;

  // Negative balances are allowed: a request is gated on credits > 0 at
  // submission time, but the post-processing deduction (cost * 100) may
  // overshoot a small remaining balance. The next request will be denied
  // until the player tops up.
  writePlayer(found.dirName, { ...found.record, credits: next });

  // Always record the change, even if delta is 0 (e.g. `set` to the same
  // value), so the audit trail captures every command that touched credits.
  appendHistory(found.dirName, delta, next, explanation);

  console.log(`${found.record.name}: ${current} -> ${next}  (${delta >= 0 ? '+' : ''}${delta}, ${explanation})`);
  process.exit(0);
}

usage();
