#!/usr/bin/env bash
# Handle a mail message from the AI inbox.
#
# Design:
#   handle-mail is the SOLE sender of reply and review-request mail. Skills
#   and sub-scripts only do the work and (for AI skills) print a structured
#   ===HANDLE_MAIL_RESULT_BEGIN===…END=== JSON block on stdout. handle-mail
#   parses that block, then composes and sends the reply (always with a
#   credits/time footer) and any optional review-request.
#
# Usage: handle-mail [<message-id>]
#   If no message ID is given, lists all unhandled requests.
set -euo pipefail

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
if [ $# -ge 1 ] && { [ "$1" = "-h" ] || [ "$1" = "--help" ]; }; then
  cat <<'EOF'
Usage: handle-mail [<message-id>]

Handle a mail message from the ai inbox. Dispatches the message to the
appropriate skill or sub-script based on its topic, sends the reply (with a
credits/time footer), optionally sends a review request, marks the message
processed, and deducts credits from the requestor.

Arguments:
  <message-id>    ID of the mail message to handle. If omitted, lists all
                  unhandled requests.

Environment:
  MECCG_LOBBY_URL   Lobby base URL (default http://localhost:8080)
  MECCG_MASTER_KEY  Lobby master key. Falls back to
                    ~/.meccg/secrets.json when unset.

Options:
  -h, --help      Show this help message.
EOF
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LOG_DIR="$HOME/.meccg/logs"
SECRETS="$HOME/.meccg/secrets.json"
PLAYERS_DIR="$HOME/.meccg/players"
AI_INFO="$PLAYERS_DIR/ai/info.json"
BASE_URL="${MECCG_LOBBY_URL:-http://localhost:8080}"
BASE_URL="${BASE_URL%/}"
COMMANDS_DIR="$PROJECT_DIR/.claude/commands"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log() { echo "[handle-mail] $*"; }

# Resolve the lobby master key. Prefers $MECCG_MASTER_KEY (required for
# remote workers that don't share the lobby's filesystem), falls back to
# ~/.meccg/secrets.json for local co-located runs.
master_key() {
  if [ -n "${MECCG_MASTER_KEY:-}" ]; then
    echo "$MECCG_MASTER_KEY"
    return 0
  fi
  if [ -f "$SECRETS" ]; then
    jq -r .masterKey "$SECRETS"
    return 0
  fi
  log "ERROR: no master key available (set MECCG_MASTER_KEY or provide $SECRETS)" >&2
  return 1
}

ai_display_name() { jq -r .displayName "$AI_INFO"; }

# Authenticate as ai and print the session cookie value.
login_ai() {
  local key
  key=$(master_key)
  curl -s -c - -X POST "$BASE_URL/api/login" \
    -H 'Content-Type: application/json' \
    -d "{\"name\":\"ai\",\"password\":\"$key\"}" \
    | grep meccg-session | awk '{print $NF}'
}

# GET with session cookie.  $1=path
api_get() {
  curl -s "$BASE_URL$1" -b "meccg-session=$SESSION"
}

# POST with master-key auth.  $1=path $2=json-body
api_post() {
  curl -s -X POST "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

# PUT with master-key auth.  $1=path $2=json-body
api_put() {
  curl -s -X PUT "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

# Update message status.  $1=username $2=msg-id $3=json-body
set_status() {
  api_put "/api/system/mail/$1/$2" "$3"
}

# Send a mail via the system API.  $1=json-body
# Returns the response (which includes the message ID).
send_mail() {
  api_post "/api/system/mail" "$1"
}

# Build a JSON mail payload.  Uses jq to avoid injection issues.
build_mail() {
  jq -n "$@"
}

# Run a Claude skill and capture the text output.
# $1=skill prompt (full text with $ARGUMENTS already substituted)
#
# The claude CLI has a known failure mode where it prints a terminal
# {"type":"result",...} line (logical completion) but does not exit,
# stalling the caller indefinitely. To stay reliable we run claude in
# the background and actively terminate it when either (a) the terminal
# result line appears, (b) claude exits on its own, or (c) a hard
# 45-minute deadline passes.
#
# The sidecar stats file includes a third line: "success" if the stream
# contained a successful terminal marker, else "error" or "timeout".
# Callers use that — not prose parsing of the summary — to decide whether
# the skill succeeded.
run_skill() {
  cd "$PROJECT_DIR"
  local raw_tmp
  raw_tmp=$(mktemp)

  claude --dangerously-skip-permissions --verbose --output-format stream-json -p "$1" > "$raw_tmp" 2>&1 &
  local claude_pid=$!

  local hard_deadline=$(( $(date +%s) + 2700 ))
  local result_seen_at=0
  local term_reason=""
  local now

  while kill -0 "$claude_pid" 2>/dev/null; do
    now=$(date +%s)
    if [ "$now" -ge "$hard_deadline" ]; then
      term_reason="hard-deadline"
      break
    fi
    if [ "$result_seen_at" -eq 0 ]; then
      if grep -q '"type":"result"' "$raw_tmp" 2>/dev/null; then
        result_seen_at=$now
        echo "[handle-mail] run_skill: terminal result emitted — allowing 10s for graceful exit" >&2
      fi
    elif [ $(( now - result_seen_at )) -ge 10 ]; then
      term_reason="post-result-hang"
      break
    fi
    sleep 2
  done

  if [ -n "$term_reason" ]; then
    echo "[handle-mail] run_skill: terminating claude (reason=$term_reason, pid=$claude_pid)" >&2
    kill -TERM "$claude_pid" 2>/dev/null || true
    local i=0
    while kill -0 "$claude_pid" 2>/dev/null && [ "$i" -lt 5 ]; do
      sleep 1
      i=$(( i + 1 ))
    done
    kill -KILL "$claude_pid" 2>/dev/null || true
  fi

  local rc
  if wait "$claude_pid" 2>/dev/null; then rc=0; else rc=$?; fi

  cat "$raw_tmp" >> "$LOG_DIR/ai-raw.log"

  local status="error"
  if grep -qE '"type":"result","subtype":"success","is_error":false' "$raw_tmp"; then
    status="success"
  elif [ "$term_reason" = "hard-deadline" ] && [ "$result_seen_at" -eq 0 ]; then
    status="timeout"
  fi
  {
    grep -oP '"total_cost_usd":\s*\K[\d.]+' "$raw_tmp" | tail -1 || true
    grep -oP '"duration_ms":\s*\K\d+' "$raw_tmp" | tail -1 || true
    echo "$status"
  } > "$LOG_DIR/.skill-stats"

  jq -r 'select(.type == "result") | .result // empty' "$raw_tmp" 2>/dev/null || true
  rm -f "$raw_tmp"

  # If the skill reached a successful terminal result, force a 0 return
  # even if we had to kill a post-result hang.
  if [ "$status" = "success" ]; then
    return 0
  fi
  return "$rc"
}

# Read cost/duration/status from the sidecar file written by run_skill.
# Sets SKILL_COST, SKILL_DURATION_MS, SKILL_STATUS (success|error|timeout).
read_skill_stats() {
  local stats_file="$LOG_DIR/.skill-stats"
  SKILL_STATUS=""
  if [ -f "$stats_file" ]; then
    SKILL_COST=$(sed -n '1p' "$stats_file")
    SKILL_DURATION_MS=$(sed -n '2p' "$stats_file")
    SKILL_STATUS=$(sed -n '3p' "$stats_file")
    rm -f "$stats_file"
  fi
  if [ -n "$SKILL_COST" ]; then
    log "Cost: \$${SKILL_COST}"
  fi
  if [ -n "$SKILL_DURATION_MS" ]; then
    local secs=$(( SKILL_DURATION_MS / 1000 ))
    local mins=$(( secs / 60 ))
    local rem_secs=$(( secs % 60 ))
    log "Duration: ${mins}m ${rem_secs}s"
  fi
  if [ -n "$SKILL_STATUS" ]; then
    log "Skill status: $SKILL_STATUS"
  fi
}

# Read a skill file, substitute $ARGUMENTS, and return the content.
load_skill() {
  local content
  content=$(cat "$COMMANDS_DIR/$1")
  echo "${content//\$ARGUMENTS/$2}"
}

# Extract the structured result block printed by an AI skill. Skills must
# print exactly one block delimited by the begin/end markers; the content
# between the markers must be a JSON object.
#   $1 = full skill stdout
extract_handler_result() {
  printf '%s\n' "$1" \
    | sed -n '/^===HANDLE_MAIL_RESULT_BEGIN===$/,/^===HANDLE_MAIL_RESULT_END===$/p' \
    | sed '1d;$d'
}

# Normalize a player name to its on-disk directory name. Mirrors the
# toDirName logic in packages/lobby-server/src/players/store.ts.
to_dir_name() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g'
}

# Read a player's current credit balance via the lobby system API. The
# endpoint returns 404 for unknown players — treat that as a 0 balance
# (matches the legacy on-disk semantics where a missing info.json meant 0).
# Prints the integer balance to stdout.
get_player_credits() {
  local user="$1"
  if [ -z "$user" ]; then echo 0; return 0; fi
  local dir resp credits
  dir=$(to_dir_name "$user")
  resp=$(curl -sf -X GET "$BASE_URL/api/system/players/$dir/credits" \
    -H "Authorization: Bearer $(master_key)" 2>/dev/null || echo '')
  if [ -z "$resp" ]; then echo 0; return 0; fi
  credits=$(echo "$resp" | jq -r '.credits // 0' 2>/dev/null)
  if [ -z "$credits" ] || [ "$credits" = "null" ]; then echo 0; return 0; fi
  echo "$credits"
}

# Deduct credits from a player via the lobby system API. The server
# records the audit entry in credits.json, identical to `bin/credits`.
#   $1=player  $2=amount(positive integer)  $3=reason(human-readable)
# No-op for empty/system accounts or non-positive amounts.
deduct_credits() {
  local user="$1" amount="$2" reason="${3:-request processing}"
  if [ -z "$user" ] || [ "$amount" -le 0 ]; then return 0; fi
  case "$user" in
    ai|admin|server) return 0 ;;
  esac
  local dir payload
  dir=$(to_dir_name "$user")
  payload=$(jq -nc --argjson amount "$(( -amount ))" --arg reason "$reason" \
    '{mode: "add", amount: $amount, reason: $reason}')
  if api_post "/api/system/players/$dir/credits" "$payload" \
      | jq -e '.balance' >/dev/null 2>&1; then
    log "Deducted $amount credits from $user ($reason)"
  else
    log "WARNING: failed to deduct $amount credits from $user"
  fi
}

# Format seconds as "Xm Ys".
format_duration() {
  local total="$1"
  local mins=$(( total / 60 ))
  local secs=$(( total % 60 ))
  echo "${mins}m ${secs}s"
}

# Look up a card's English name from data/cards.json by card ID
# (e.g. "tw-156"). Returns empty if the card or file is not found.
# cards.json uses uppercase set codes and card IDs; our internal IDs
# are lowercase, so we normalize before the lookup.
lookup_card_name() {
  local id="$1"
  if [ -z "$id" ]; then return 0; fi
  local id_upper set_upper num lookup_id
  id_upper=$(echo "$id" | tr 'a-z' 'A-Z')
  set_upper="${id_upper%%-*}"
  # cards.json keys are unpadded (TW-16), our internal IDs are padded (tw-016).
  num="${id_upper#*-}"
  num=$((10#$num))
  lookup_id="${set_upper}-${num}"
  jq -r --arg set "$set_upper" --arg id "$lookup_id" \
    '.[$set].cards[$id].name.en // empty' \
    "$PROJECT_DIR/data/cards.json" 2>/dev/null || true
}

# Send the reply mail to a single recipient. The credits/time footer is
# always appended to the body. This is the SOLE place that emits reply mail.
#   $1=recipient  $2=topic  $3=subject  $4=body  $5=keywords-json
send_reply_mail() {
  local recipient="$1" topic="$2" subject="$3" body="$4" kw="$5"
  if [ -z "$recipient" ] || [ -z "$topic" ]; then
    log "WARNING: send_reply_mail called with empty recipient or topic — skipping"
    return 0
  fi
  if [ -z "$kw" ] || [ "$kw" = "{}" ]; then
    kw=$(jq -n --arg origId "$MSG_ID" '{originalMessageId: $origId}')
  fi

  local footer
  footer="

---
*Processed in ${DURATION_HUMAN}. Charged ${CREDITS_CHARGED} credits.*"
  body="${body}${footer}"

  local from_name
  from_name=$(ai_display_name)

  local payload
  payload=$(build_mail \
    --argjson recipients "[\"$recipient\"]" \
    --arg from "$from_name" \
    --arg topic "$topic" \
    --arg subject "$subject" \
    --arg body "$body" \
    --argjson keywords "$kw" \
    --arg replyTo "$MSG_ID" \
    '{recipients: $recipients, sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  log "Sending reply ($topic) to $recipient..."
  send_mail "$payload" >/dev/null
}

# Send a review request to one or more reviewers. No footer (reviews are not
# user-facing replies). Marks each recipient's copy as 'waiting' afterwards.
#   $1=topic  $2=subject  $3=body  $4=recipients-json-array  $5=keywords-json
send_review_request() {
  local rtopic="$1" rsubj="$2" rbody="$3" rrecipients="$4" rkw="$5"
  if [ -z "$rtopic" ] || [ -z "$rrecipients" ]; then
    return 0
  fi
  local from_name
  from_name=$(ai_display_name)

  local payload
  payload=$(build_mail \
    --argjson recipients "$rrecipients" \
    --arg from "$from_name" \
    --arg topic "$rtopic" \
    --arg subject "$rsubj" \
    --arg body "$rbody" \
    --argjson keywords "$rkw" \
    --arg replyTo "$MSG_ID" \
    '{recipients: $recipients, sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  log "Sending review request: $rsubj"
  local resp
  resp=$(send_mail "$payload")

  local review_id
  review_id=$(echo "$resp" | jq -r '.id // empty')
  if [ -n "$review_id" ]; then
    while IFS= read -r reviewer; do
      [ -n "$reviewer" ] || continue
      set_status "$reviewer" "$review_id" '{"status":"waiting"}' || true
    done < <(echo "$rrecipients" | jq -r '.[]')
    log "Review request sent ($review_id) and marked as waiting."
  else
    log "WARNING: Could not extract review message ID from response."
  fi
}

# ---------------------------------------------------------------------------
# No message ID — list inbox
# ---------------------------------------------------------------------------

if [ $# -eq 0 ] || [ -z "${1:-}" ]; then
  log "No message ID provided. Listing unhandled requests..."
  "$SCRIPT_DIR/requests"
  exit 0
fi

MSG_ID="$1"

# ---------------------------------------------------------------------------
# Step 1: Log in
# ---------------------------------------------------------------------------

log "Logging in as ai..."
SESSION=$(login_ai)
if [ -z "$SESSION" ]; then
  log "ERROR: Failed to log in as ai"
  exit 1
fi
log "Logged in."

# ---------------------------------------------------------------------------
# Step 2: Fetch the message
# ---------------------------------------------------------------------------

log "Fetching message $MSG_ID..."
MSG=$(api_get "/api/mail/inbox/$MSG_ID")

if echo "$MSG" | jq -e '.error' &>/dev/null; then
  log "ERROR: Message not found: $(echo "$MSG" | jq -r '.error')"
  exit 1
fi

TOPIC=$(echo "$MSG" | jq -r '.topic // empty')
SUBJECT=$(echo "$MSG" | jq -r '.subject // empty')
FROM=$(echo "$MSG" | jq -r '.from // empty')
SENDER=$(echo "$MSG" | jq -r '.sender // empty')
KEYWORDS=$(echo "$MSG" | jq -c '.keywords // {}')

log "Message $MSG_ID: \"$SUBJECT\" from $FROM (topic: $TOPIC)"

# ---------------------------------------------------------------------------
# Step 2b: Resolve the requestor and verify they have credits left.
# ---------------------------------------------------------------------------
# We never start (potentially expensive) handling for a player whose credit
# balance is already zero or below. Mirror the post-handling billing logic
# so we check the same account that would be charged: prefer an explicit
# `originalRequestor` keyword (set by the planning skill and forwarded by
# the lobby through to implementation requests), then `userName` from the
# inbound keywords, then the message's `from` field. System accounts
# (ai/admin/server) are never billed and are not gated.

DEFAULT_RECIPIENT=$(echo "$KEYWORDS" | jq -r '.userName // empty')
if [ -z "$DEFAULT_RECIPIENT" ]; then
  DEFAULT_RECIPIENT="$FROM"
fi

REQUESTOR=$(echo "$KEYWORDS" | jq -r '.originalRequestor // empty')
if [ -z "$REQUESTOR" ]; then
  REQUESTOR="$DEFAULT_RECIPIENT"
fi

case "$REQUESTOR" in
  ai|admin|server|"") ;;  # never billed, skip the gate
  *)
    REQUESTOR_CREDITS=$(get_player_credits "$REQUESTOR")
    log "Requestor '$REQUESTOR' has $REQUESTOR_CREDITS credits."
    if [ "$REQUESTOR_CREDITS" -le 0 ]; then
      log "Skipping handling: '$REQUESTOR' has no credits left ($REQUESTOR_CREDITS). Leaving message unprocessed."
      exit 0
    fi
    ;;
esac

# ---------------------------------------------------------------------------
# Step 2c: Refuse to start on a polluted working tree.
# ---------------------------------------------------------------------------
# A dirty tree almost always means a previous skill ended without
# committing and pushing its work. Hiding that with `git stash` made
# the problem invisible and let half-finished edits rot across runs.
# Instead we bail loudly: the operator must convert the leftover work
# into a proper PR (or revert it) before any new mail is handled.

cd "$PROJECT_DIR"
if [ -n "$(git status --porcelain)" ]; then
  log "FATAL: working tree is dirty before handling $MSG_ID. Refusing to proceed."
  log "The previous run left uncommitted changes — these must become a PR or be"
  log "reverted manually before run-ai can continue. Dirty files:"
  git status --porcelain | sed 's/^/[handle-mail]   /'
  exit 2
fi

# ---------------------------------------------------------------------------
# Step 3: Mark as processing
# ---------------------------------------------------------------------------

log "Marking as processing..."
set_status "ai" "$MSG_ID" '{"status":"processing"}'

# ---------------------------------------------------------------------------
# Dispatch state
# ---------------------------------------------------------------------------

SUCCESS=false
SKILL_COST=""
SKILL_DURATION_MS=""
SKILL_STATUS=""
SKILL_OUTPUT=""

REPLY_RECIPIENT=""
REPLY_TOPIC=""
REPLY_SUBJECT=""
REPLY_BODY=""
REPLY_KEYWORDS="{}"

REVIEW_TOPIC=""
REVIEW_SUBJECT=""
REVIEW_BODY=""
REVIEW_RECIPIENTS=""
REVIEW_KEYWORDS="{}"

# Default reply recipient was resolved above (Step 2b) so we could run the
# credit gate against the same account that will eventually be billed.
# Reusing it here keeps the dispatch and billing in sync.

# ---------------------------------------------------------------------------
# Step 4: Dispatch based on topic
# ---------------------------------------------------------------------------

DISPATCH_START=$(date +%s)

case "$TOPIC" in

  # =========================================================================
  card-request)
    CARD_NAME=$(echo "$KEYWORDS" | jq -r '.cardName // empty')
    DECK_ID=$(echo "$KEYWORDS" | jq -r '.deckId // empty')
    USER_NAME=$(echo "$KEYWORDS" | jq -r '.userName // empty')
    REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
    REPLY_TOPIC="card-reply"

    if [ -z "$CARD_NAME" ] || [ -z "$DECK_ID" ]; then
      REPLY_SUBJECT="Failed to add: $SUBJECT"
      REPLY_BODY="Missing cardName or deckId in message keywords."
      log "ERROR: Missing cardName or deckId in message keywords."
    else
      log "Card request: $CARD_NAME for deck $DECK_ID (requested by $USER_NAME)"
      log "Running bin/add-card.mjs..."
      cd "$PROJECT_DIR"
      ADD_OUTPUT=$(node bin/add-card.mjs "$CARD_NAME" "$DECK_ID" 2>&1) && RC=$? || RC=$?
      log "add-card.mjs completed (exit $RC)."

      # Extract git hash
      GIT_HASH=$(echo "$ADD_OUTPUT" | grep -oP '(?<=commit hash[:\s]*)[0-9a-f]{7,40}' | tail -1 || true)
      if [ -z "$GIT_HASH" ]; then
        GIT_HASH=$(echo "$ADD_OUTPUT" | grep -oP '[0-9a-f]{40}' | tail -1 || true)
      fi
      if [ -z "$GIT_HASH" ]; then
        GIT_HASH=$(cd "$PROJECT_DIR" && git rev-parse HEAD)
      fi

      if echo "$ADD_OUTPUT" | grep -qiP '(successfully added|card.*added|commit.*push|pushed)'; then
        SUCCESS=true

        # Try to find the card image from data files
        CARD_ID=$(echo "$ADD_OUTPUT" | grep -oP '(?:card.?id|definition.?id)[:\s]*"?([a-z]+-[0-9]+)"?' | grep -oP '[a-z]+-[0-9]+' | head -1 || true)
        IMAGE_MD=""
        if [ -n "$CARD_ID" ]; then
          SET_PREFIX="${CARD_ID%%-*}"
          IMAGE_FILE=$(cd "$PROJECT_DIR" && grep -r "\"$CARD_ID\"" packages/shared/src/data/ 2>/dev/null \
            | head -1 | grep -oP '"image":\s*"[^"]*"' | grep -oP 'https?://[^"]+' || true)
          if [ -n "$IMAGE_FILE" ]; then
            IMG_FILENAME=$(basename "$IMAGE_FILE")
            IMAGE_MD="![${CARD_NAME}](/cards/images/${SET_PREFIX}/${IMG_FILENAME})"
          fi
        fi

        REPLY_SUBJECT="Added: $CARD_NAME"
        REPLY_BODY="$IMAGE_MD

The card **$CARD_NAME** ($CARD_ID) has been added to the card pool.

Commit: https://github.com/wigy/meccg/commit/$GIT_HASH"
        REPLY_KEYWORDS=$(jq -n \
          --arg origId "$MSG_ID" \
          --arg cardName "$CARD_NAME" \
          --arg cardId "$CARD_ID" \
          --arg gitHash "$GIT_HASH" \
          '{originalMessageId: $origId, cardName: $cardName, cardId: $cardId, gitHash: $gitHash}')

        REVIEW_TOPIC="review-request"
        REVIEW_SUBJECT="Review: $CARD_NAME added"
        REVIEW_BODY="${IMAGE_MD}

**$CARD_NAME** ($CARD_ID) was added from a card request by $USER_NAME.

Commit: https://github.com/wigy/meccg/commit/$GIT_HASH"
        REVIEW_RECIPIENTS='["wigy","karmi","admin"]'
        REVIEW_KEYWORDS=$(jq -n \
          --arg cardName "$CARD_NAME" \
          --arg cardId "$CARD_ID" \
          --arg gitHash "$GIT_HASH" \
          --arg userName "$USER_NAME" \
          '{cardName: $cardName, cardId: $cardId, gitHash: $gitHash, userName: $userName}')
      else
        REPLY_SUBJECT="Failed to add: $CARD_NAME"
        REPLY_BODY="Card request handler did not indicate success. Output tail:
$(echo "$ADD_OUTPUT" | tail -20)"
      fi
    fi
    ;;

  # =========================================================================
  certification-request)
    CARD_ID=$(echo "$KEYWORDS" | jq -r '.cardId // empty')
    USER_NAME=$(echo "$KEYWORDS" | jq -r '.userName // empty')
    REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
    REPLY_TOPIC="certification-reply"

    if [ -z "$CARD_ID" ]; then
      REPLY_SUBJECT="Certification failed: missing cardId"
      REPLY_BODY="Missing cardId in message keywords."
      log "ERROR: Missing cardId in message keywords."
    else
      log "Certification request: $CARD_ID (requested by $USER_NAME)"

      PROMPT=$(load_skill "handle-certify-card.md" "$CARD_ID")
      PROMPT="$PROMPT

IMPORTANT: You MUST create a branch named certify-${CARD_ID}-<card-slug>, commit there, push, and open a PR. Do NOT commit to master."

      SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
      read_skill_stats
      log "Handler completed (exit $RC, status=${SKILL_STATUS:-unknown})."

      CARD_NAME=$(lookup_card_name "$CARD_ID")
      GIT_HASH=$(echo "$SKILL_OUTPUT" | grep -oP '[0-9a-f]{40}' | tail -1 || true)

      # Safety net: the certify skill is required to leave the working
      # tree clean (either no changes, or all changes committed on its
      # certify-<cardId>-* branch). If it didn't, we do NOT stash —
      # stashing hid half-finished work across runs. Leave the dirty
      # files in place so run-ai refuses to continue until the operator
      # opens a PR for them or reverts.
      cd "$PROJECT_DIR"
      DIRTY_FILES=""
      if [ -n "$(git status --porcelain)" ]; then
        DIRTY_FILES=$(git status --porcelain)
        log "WARNING: skill left $(echo "$DIRTY_FILES" | wc -l) uncommitted file(s)."
        echo "$DIRTY_FILES" | sed 's/^/[handle-mail]   /'
      fi

      # Look up the PR by its head branch. The skill creates the branch
      # certify-<cardId>-<slug>. We list PRs and match by headRefName
      # prefix client-side — safer than --head (exact match) or --search
      # (fuzzy GitHub search).
      PR_URL=$(cd "$PROJECT_DIR" && gh pr list --state all --limit 500 \
        --json url,headRefName \
        -q "[.[] | select(.headRefName | startswith(\"certify-${CARD_ID}-\")) | .url][0] // empty" \
        2>/dev/null || true)

      # Artifact-based success detection. No prose parsing: we trust
      # (a) the stream-json terminal success marker captured by
      # run_skill, (b) the existence of a PR on the certify branch,
      # and (c) a clean working tree. Any uncommitted leftovers mean
      # the skill abandoned its turn mid-step and the reply must say so.
      CERT_FAIL_REASON=""
      if [ -n "$DIRTY_FILES" ]; then
        CERT_FAIL_REASON="Skill exited with uncommitted changes — it ended its turn before reaching step 14 (branch/commit/push/PR). The run-ai loop will refuse to handle more mail until these files are turned into a PR or reverted.

Uncommitted files:
$DIRTY_FILES"
      elif [ "${SKILL_STATUS:-}" != "success" ]; then
        CERT_FAIL_REASON="Skill did not reach a successful terminal result (status=${SKILL_STATUS:-unknown})."
      elif [ -z "$PR_URL" ]; then
        CERT_FAIL_REASON="No PR was opened for certify-${CARD_ID}-* (skill step 14 not completed)."
      fi

      if [ -z "$CERT_FAIL_REASON" ]; then
        SUCCESS=true
        REPLY_SUBJECT="Certified: $CARD_ID"
        REPLY_BODY="Card **$CARD_ID** ($CARD_NAME) has been certified.

PR: $PR_URL"
        REPLY_KEYWORDS=$(jq -n \
          --arg origId "$MSG_ID" \
          --arg cardId "$CARD_ID" \
          --arg prUrl "$PR_URL" \
          --arg gitHash "$GIT_HASH" \
          '{originalMessageId: $origId, cardId: $cardId, prUrl: $prUrl, gitHash: $gitHash}')

        REVIEW_TOPIC="review-request"
        REVIEW_SUBJECT="Review: $CARD_ID certified"
        REVIEW_BODY="Card **$CARD_ID** ($CARD_NAME) has been certified.

PR: $PR_URL"
        REVIEW_RECIPIENTS='["wigy","karmi","admin"]'
        REVIEW_KEYWORDS=$(jq -n \
          --arg cardName "$CARD_NAME" \
          --arg cardId "$CARD_ID" \
          --arg gitHash "$GIT_HASH" \
          --arg prUrl "$PR_URL" \
          --arg userName "$USER_NAME" \
          '{cardName: $cardName, cardId: $cardId, gitHash: $gitHash, prUrl: $prUrl, userName: $userName}')
      else
        REPLY_SUBJECT="Certification failed: $CARD_ID"
        REPLY_BODY="Certification of **$CARD_ID** ($CARD_NAME) was not completed.

Reason: $CERT_FAIL_REASON

Output tail:
$(echo "$SKILL_OUTPUT" | tail -40)"
        log "Certification failed: $CERT_FAIL_REASON"
      fi
    fi
    ;;

  # =========================================================================
  feature-planning-request|feature-implementation-request|bug-report|review-fix-request)
    case "$TOPIC" in
      feature-planning-request)       SKILL_FILE="handle-planning-request.md" ;;
      feature-implementation-request) SKILL_FILE="handle-implementation-request.md" ;;
      bug-report)                     SKILL_FILE="handle-bug-report.md" ;;
      review-fix-request)             SKILL_FILE="handle-review-fix-request.md" ;;
    esac

    log "Dispatching topic \"$TOPIC\" to $SKILL_FILE..."
    PROMPT=$(load_skill "$SKILL_FILE" "$MSG_ID")
    SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
    read_skill_stats
    log "Handler completed (exit $RC)."

    # Post-skill dirty-tree check. These skills must either (a) commit +
    # push + open a PR and leave the working tree clean, or (b) revert
    # any edits they made and emit success:false. If the tree is dirty,
    # the skill failed either way — override whatever it printed and
    # report the real state. We do NOT stash: the leftover files must
    # stay in place so run-ai refuses to continue until the operator
    # turns them into a PR or reverts.
    cd "$PROJECT_DIR"
    SKILL_DIRTY_FILES=""
    if [ -n "$(git status --porcelain)" ]; then
      SKILL_DIRTY_FILES=$(git status --porcelain)
      log "WARNING: $SKILL_FILE left $(echo "$SKILL_DIRTY_FILES" | wc -l) uncommitted file(s)."
      echo "$SKILL_DIRTY_FILES" | sed 's/^/[handle-mail]   /'
    fi

    REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
    REPLY_TOPIC="${TOPIC/request/reply}"
    REPLY_TOPIC="${REPLY_TOPIC/bug-report/bug-reply}"

    RESULT_JSON=$(extract_handler_result "$SKILL_OUTPUT")
    HAS_VALID_RESULT=false
    if [ -n "$RESULT_JSON" ] && echo "$RESULT_JSON" | jq -e . >/dev/null 2>&1; then
      HAS_VALID_RESULT=true
    fi

    if [ -n "$SKILL_DIRTY_FILES" ]; then
      # Dirty tree overrides whatever the skill said — it didn't finish.
      log "ERROR: Skill left the working tree dirty — reporting as failure."
      REPLY_SUBJECT="Failed: $SUBJECT"
      REPLY_BODY="The handler for this request did not commit or push its work. It left $(echo "$SKILL_DIRTY_FILES" | wc -l) file(s) uncommitted in the working tree:

$SKILL_DIRTY_FILES

No PR was opened. The run-ai loop will refuse to handle more mail until these files are turned into a PR or reverted manually."
    elif ! $HAS_VALID_RESULT; then
      log "ERROR: Skill did not produce a valid HANDLE_MAIL_RESULT block."
      REPLY_SUBJECT="Failed: $SUBJECT"
      REPLY_BODY="The handler did not produce structured output. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
    else
      if [ "$(echo "$RESULT_JSON" | jq -r '.success // false')" = "true" ]; then
        SUCCESS=true
      fi
      REPLY_RECIPIENT=$(echo "$RESULT_JSON" | jq -r '.reply.recipient // empty')
      [ -z "$REPLY_RECIPIENT" ] && REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
      REPLY_TOPIC=$(echo "$RESULT_JSON" | jq -r '.reply.topic // empty')
      REPLY_SUBJECT=$(echo "$RESULT_JSON" | jq -r '.reply.subject // empty')
      REPLY_BODY=$(echo "$RESULT_JSON" | jq -r '.reply.body // empty')
      REPLY_KEYWORDS=$(echo "$RESULT_JSON" | jq -c '.reply.keywords // {}')

      REVIEW_TOPIC=$(echo "$RESULT_JSON" | jq -r '.review.topic // empty')
      REVIEW_SUBJECT=$(echo "$RESULT_JSON" | jq -r '.review.subject // empty')
      REVIEW_BODY=$(echo "$RESULT_JSON" | jq -r '.review.body // empty')
      REVIEW_RECIPIENTS=$(echo "$RESULT_JSON" | jq -c '.review.recipients // empty')
      REVIEW_KEYWORDS=$(echo "$RESULT_JSON" | jq -c '.review.keywords // {}')
    fi
    ;;

  # =========================================================================
  feature-request|bug-fix-request)
    log "Topic \"$TOPIC\" cannot be automatically handled."
    REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
    REPLY_TOPIC="${TOPIC/request/reply}"
    REPLY_SUBJECT="Cannot auto-handle: $SUBJECT"
    REPLY_BODY="This type of request ($TOPIC) requires manual attention and cannot be processed automatically."
    ;;

  # =========================================================================
  *)
    log "Unknown or unsupported topic: $TOPIC"
    REPLY_RECIPIENT="$DEFAULT_RECIPIENT"
    REPLY_TOPIC="error-reply"
    REPLY_SUBJECT="Unprocessable: $SUBJECT"
    REPLY_BODY="Unknown or unsupported topic: $TOPIC. The message could not be processed."
    ;;
esac

DISPATCH_END=$(date +%s)
DISPATCH_DURATION_S=$(( DISPATCH_END - DISPATCH_START ))

# ---------------------------------------------------------------------------
# Step 5: Compute credits + duration footer values
# ---------------------------------------------------------------------------
# Card requests are mechanical (no AI cost) and charge a flat 5 credits.
# Everything else charges round(SKILL_COST * 100) credits — i.e. 1 credit
# per cent of actual Claude usage. Charging happens regardless of success
# because the cost was incurred either way.

CREDITS_CHARGED=0
if [ "$TOPIC" = "card-request" ]; then
  CREDITS_CHARGED=5
elif [ -n "${SKILL_COST:-}" ]; then
  CREDITS_CHARGED=$(awk -v c="$SKILL_COST" 'BEGIN { printf "%d", (c*100)+0.5 }')
fi

# Certification failures don't bill: the user paid for a PR + test, not for
# an analysis of why we can't ship one. The Claude cost is sunk for us, but
# charging on failure is the wrong incentive — and surprised users twice
# (Stinker le-154, Warg-king le-158, etc.).
if [ "$TOPIC" = "certification-request" ] && ! $SUCCESS; then
  CREDITS_CHARGED=0
fi

# Human-readable reason for the credit-history audit log. Card-related
# topics must always name the card — never show only the bare ID code.
case "$TOPIC" in
  card-request)
    if [ -n "${CARD_NAME:-}" ] && [ -n "${CARD_ID:-}" ]; then
      CREDITS_REASON="Card request: $CARD_NAME ($CARD_ID)"
    else
      CREDITS_REASON="Card request: ${CARD_NAME:-${CARD_ID:-unknown}}"
    fi
    ;;
  certification-request)
    if [ -n "${CARD_NAME:-}" ] && [ -n "${CARD_ID:-}" ]; then
      CREDITS_REASON="Certification: $CARD_NAME ($CARD_ID)"
    else
      CREDITS_REASON="Certification: ${CARD_NAME:-${CARD_ID:-unknown}}"
    fi
    ;;
  feature-planning-request)
    # Subject arrives as "Plan Feature: Feature Request: <brief>" — strip the
    # nested prefixes so the credit reason isn't double/triple-labelled.
    CLEAN_SUBJECT="$SUBJECT"
    CLEAN_SUBJECT="${CLEAN_SUBJECT#Plan Feature: }"
    CLEAN_SUBJECT="${CLEAN_SUBJECT#Feature Request: }"
    CREDITS_REASON="Feature planning: $CLEAN_SUBJECT"
    ;;
  feature-implementation-request)
    # Subject arrives as "Implement: Plan Feature: Feature Request: <brief>".
    CLEAN_SUBJECT="$SUBJECT"
    CLEAN_SUBJECT="${CLEAN_SUBJECT#Implement: }"
    CLEAN_SUBJECT="${CLEAN_SUBJECT#Plan Feature: }"
    CLEAN_SUBJECT="${CLEAN_SUBJECT#Feature Request: }"
    CREDITS_REASON="Feature implementation: $CLEAN_SUBJECT"
    ;;
  bug-report)
    # Subject arrives as "Bug Report: <brief>".
    CLEAN_SUBJECT="${SUBJECT#Bug Report: }"
    CREDITS_REASON="Bug report: $CLEAN_SUBJECT"
    ;;
  review-fix-request)
    # Subject arrives as "Fix Review: <brief>".
    CLEAN_SUBJECT="${SUBJECT#Fix Review: }"
    CREDITS_REASON="Review fix: $CLEAN_SUBJECT"
    ;;
  *)                              CREDITS_REASON="$TOPIC: $SUBJECT" ;;
esac

DURATION_HUMAN=$(format_duration "$DISPATCH_DURATION_S")

# ---------------------------------------------------------------------------
# Step 6: Send the reply — or stash it for lobby approval
# ---------------------------------------------------------------------------
# When the review-request carries a PR URL, the reply to the requestor is
# withheld until the reviewer approves the review-request in the lobby. We
# serialize the full reply (already including the credits/time footer) into
# the review-request's keywords as `pendingReplyJson`; the lobby approve
# handler recovers it and sends the mail.
# Topics that don't open a PR (card-request, feature-planning-request) send
# the reply immediately as before.

HAS_PR_REVIEW=false
if [ -n "$REVIEW_TOPIC" ] && [ "$REVIEW_KEYWORDS" != "{}" ]; then
  if echo "$REVIEW_KEYWORDS" | jq -e '(.prUrl // "") | select(length > 0)' >/dev/null 2>&1; then
    HAS_PR_REVIEW=true
  fi
fi

if [ -n "$REPLY_TOPIC" ] && $HAS_PR_REVIEW; then
  log "Stashing reply into review-request keywords (will be sent by lobby on approval)"
  FOOTER="

---
*Processed in ${DURATION_HUMAN}. Charged ${CREDITS_CHARGED} credits.*"
  STASHED_BODY="${REPLY_BODY}${FOOTER}"
  PENDING_REPLY_JSON=$(jq -nc \
    --arg recipient "$REPLY_RECIPIENT" \
    --arg topic "$REPLY_TOPIC" \
    --arg subject "$REPLY_SUBJECT" \
    --arg body "$STASHED_BODY" \
    --argjson keywords "$REPLY_KEYWORDS" \
    --arg replyTo "$MSG_ID" \
    '{recipient: $recipient, topic: $topic, subject: $subject, body: $body, keywords: $keywords, replyTo: $replyTo}')
  REVIEW_KEYWORDS=$(echo "$REVIEW_KEYWORDS" | jq -c --arg pr "$PENDING_REPLY_JSON" '. + {pendingReplyJson: $pr}')
elif [ -n "$REPLY_TOPIC" ]; then
  send_reply_mail "$REPLY_RECIPIENT" "$REPLY_TOPIC" "$REPLY_SUBJECT" "$REPLY_BODY" "$REPLY_KEYWORDS"
fi

# ---------------------------------------------------------------------------
# Step 7: Send the optional review request (no footer)
# ---------------------------------------------------------------------------

if [ -n "$REVIEW_TOPIC" ] && [ -n "$REVIEW_RECIPIENTS" ]; then
  send_review_request "$REVIEW_TOPIC" "$REVIEW_SUBJECT" "$REVIEW_BODY" "$REVIEW_RECIPIENTS" "$REVIEW_KEYWORDS"
fi

# ---------------------------------------------------------------------------
# Step 8: Mark message as processed
# ---------------------------------------------------------------------------

if $SUCCESS; then
  log "Marking message as processed (success: true)"
  set_status "ai" "$MSG_ID" '{"status":"processed","success":true}'
else
  log "Marking message as processed (success: false)"
  set_status "ai" "$MSG_ID" '{"status":"processed","success":false}'
fi

# ---------------------------------------------------------------------------
# Step 9: Deduct credits from the requestor
# ---------------------------------------------------------------------------
# Most replies bill the reply recipient (the person whose request is being
# answered). Planning and implementation requests are different: they are
# forwarded by a reviewer (typically admin) from a feature-request that
# originally came from a real user, so the reply goes back to the reviewer
# but the bill must follow the original requestor. The planning skill
# resolves that user and writes their username into its reply keywords as
# `originalRequestor`; the lobby server then forwards that field through to
# the implementation request, and the implementation skill copies it into
# its own reply keywords. Honor it here for both flows.

CREDIT_TARGET="$REPLY_RECIPIENT"
ORIGINAL_REQUESTOR=$(echo "$REPLY_KEYWORDS" | jq -r '.originalRequestor // empty')
if [ -n "$ORIGINAL_REQUESTOR" ]; then
  CREDIT_TARGET="$ORIGINAL_REQUESTOR"
  log "Billing original requestor '$ORIGINAL_REQUESTOR' instead of reply recipient '$REPLY_RECIPIENT'"
fi

if [ "$CREDITS_CHARGED" -gt 0 ]; then
  deduct_credits "$CREDIT_TARGET" "$CREDITS_CHARGED" "$CREDITS_REASON"
fi

# ---------------------------------------------------------------------------
# Step 10: Report
# ---------------------------------------------------------------------------

echo ""
log "=== Summary ==="
log "Message:  $MSG_ID"
log "Topic:    $TOPIC"
log "Subject:  $SUBJECT"
log "From:     $FROM"
log "Success:  $SUCCESS"
if ! $SUCCESS && [ -n "${CERT_FAIL_REASON:-}" ]; then
  # Surface the first line of the failure reason in the terminal summary
  # so operators reading the log don't have to open the reply to see why.
  log "Reason:   $(echo "$CERT_FAIL_REASON" | head -1)"
fi
if [ -n "$REPLY_TOPIC" ]; then
  log "Reply:    $REPLY_TOPIC -> $REPLY_RECIPIENT"
fi
if [ -n "$REVIEW_TOPIC" ]; then
  log "Review:   $REVIEW_TOPIC -> $REVIEW_RECIPIENTS"
fi
if [ -n "${SKILL_COST:-}" ]; then
  log "Cost:     \$${SKILL_COST}"
fi
log "Duration: $DURATION_HUMAN"
if [ "$CREDITS_CHARGED" -gt 0 ]; then
  log "Credits:  -${CREDITS_CHARGED} (from $CREDIT_TARGET)"
fi
