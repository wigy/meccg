#!/usr/bin/env bash
# Handle a mail message from the AI inbox by dispatching it to the appropriate
# Claude skill based on its topic and keywords.
#
# Usage: handle-mail [<message-id>]
#   If no message ID is given, lists all unhandled requests.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LOG_DIR="$HOME/.meccg/logs"
SECRETS="$HOME/.meccg/secrets.json"
AI_INFO="$HOME/.meccg/players/ai/info.json"
BASE_URL="http://localhost:8080"
COMMANDS_DIR="$PROJECT_DIR/.claude/commands"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log() { echo "[handle-mail] $*"; }

master_key() { jq -r .masterKey "$SECRETS"; }

ai_display_name() { jq -r .displayName "$AI_INFO"; }

# Authenticate as ai and print the session cookie value.
login_ai() {
  local key
  key=$(master_key)
  curl -s -c - -X POST "$BASE_URL/api/login" \
    -H 'Content-Type: application/json' \
    -d "{\"name\":\"ai\",\"password\":\"$key\"}" \
    | grep meccg-session | awk '{print $NF}'
}

# GET with session cookie.  $1=path
api_get() {
  curl -s "$BASE_URL$1" -b "meccg-session=$SESSION"
}

# POST with master-key auth.  $1=path $2=json-body
api_post() {
  curl -s -X POST "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

# PUT with master-key auth.  $1=path $2=json-body
api_put() {
  curl -s -X PUT "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

# Update message status.  $1=username $2=msg-id $3=json-body
set_status() {
  api_put "/api/system/mail/$1/$2" "$3"
}

# Send a mail via the system API.  $1=json-body
# Returns the response (which includes the message ID).
send_mail() {
  api_post "/api/system/mail" "$1"
}

# Build a JSON mail payload.  Uses jq to avoid injection issues.
# Arguments are passed as jq --arg pairs followed by the jq filter.
build_mail() {
  jq -n "$@"
}

# Run a Claude skill and capture the text output.
# $1=skill prompt (full text with $ARGUMENTS already substituted)
# Prints the output to stdout; returns Claude's exit code.
run_skill() {
  cd "$PROJECT_DIR"
  local raw_tmp
  raw_tmp=$(mktemp)
  claude --dangerously-skip-permissions --verbose --output-format stream-json -p "$1" > "$raw_tmp" 2>&1
  local rc=$?
  cat "$raw_tmp" >> "$LOG_DIR/ai-raw.log"
  # Extract cost/time into global variables and print summary lines
  SKILL_COST=$(grep -oP '"total_cost_usd":\s*\K[\d.]+' "$raw_tmp" | tail -1 || true)
  SKILL_DURATION_MS=$(grep -oP '"duration_ms":\s*\K\d+' "$raw_tmp" | tail -1 || true)
  if [ -n "$SKILL_COST" ]; then
    log "Cost: \$${SKILL_COST}"
  fi
  if [ -n "$SKILL_DURATION_MS" ]; then
    local secs=$(( SKILL_DURATION_MS / 1000 ))
    local mins=$(( secs / 60 ))
    local rem_secs=$(( secs % 60 ))
    log "Duration: ${mins}m ${rem_secs}s"
  fi
  # Extract the text result for the caller
  jq -r 'select(.type == "result") | .result // empty' "$raw_tmp" 2>/dev/null || true
  rm -f "$raw_tmp"
  return $rc
}

# Read a skill file, substitute $ARGUMENTS, and return the content.
# $1=skill filename (e.g. handle-card-request.md)  $2=arguments string
load_skill() {
  local content
  content=$(cat "$COMMANDS_DIR/$1")
  echo "${content//\$ARGUMENTS/$2}"
}

# ---------------------------------------------------------------------------
# No message ID — list inbox
# ---------------------------------------------------------------------------

if [ $# -eq 0 ] || [ -z "${1:-}" ]; then
  log "No message ID provided. Listing unhandled requests..."
  "$SCRIPT_DIR/list-requests"
  exit 0
fi

MSG_ID="$1"

# ---------------------------------------------------------------------------
# Step 1: Log in
# ---------------------------------------------------------------------------

log "Logging in as ai..."
SESSION=$(login_ai)
if [ -z "$SESSION" ]; then
  log "ERROR: Failed to log in as ai"
  exit 1
fi
log "Logged in."

# ---------------------------------------------------------------------------
# Step 2: Fetch the message
# ---------------------------------------------------------------------------

log "Fetching message $MSG_ID..."
MSG=$(api_get "/api/mail/inbox/$MSG_ID")

# Check if message was found
if echo "$MSG" | jq -e '.error' &>/dev/null; then
  log "ERROR: Message not found: $(echo "$MSG" | jq -r '.error')"
  exit 1
fi

TOPIC=$(echo "$MSG" | jq -r '.topic // empty')
SUBJECT=$(echo "$MSG" | jq -r '.subject // empty')
FROM=$(echo "$MSG" | jq -r '.from // empty')
SENDER=$(echo "$MSG" | jq -r '.sender // empty')
BODY=$(echo "$MSG" | jq -r '.body // empty')
KEYWORDS=$(echo "$MSG" | jq -c '.keywords // {}')

log "Message $MSG_ID: \"$SUBJECT\" from $FROM (topic: $TOPIC)"

# ---------------------------------------------------------------------------
# Step 3: Mark as processing
# ---------------------------------------------------------------------------

log "Marking as processing..."
set_status "ai" "$MSG_ID" '{"status":"processing"}'

# ---------------------------------------------------------------------------
# Dispatch helpers
# ---------------------------------------------------------------------------

SUCCESS=false
DELEGATED=false
SKILL_COST=""
SKILL_DURATION_MS=""
REPLY_TOPIC=""
REPLY_SUBJECT=""
REPLY_BODY=""
REPLY_KEYWORDS="{}"
SKILL_OUTPUT=""

# Determine the reply recipient: prefer userName keyword, fall back to sender
RECIPIENT=$(echo "$KEYWORDS" | jq -r '.userName // empty')
if [ -z "$RECIPIENT" ]; then
  RECIPIENT="$SENDER"
fi

# Mark message as processed and send a failure reply.
# $1=error description
fail() {
  local desc="$1"
  SUCCESS=false
  REPLY_BODY="$desc"
  log "Handler failed: $desc"
}

# Send review request to admins.  $1=topic $2=subject $3=body $4=keywords(json)
send_review_request() {
  local rtopic="$1" rsubj="$2" rbody="$3" rkw="$4"
  local from_name
  from_name=$(ai_display_name)

  local payload
  payload=$(build_mail \
    --arg from "$from_name" \
    --arg topic "$rtopic" \
    --arg subject "$rsubj" \
    --arg body "$rbody" \
    --argjson keywords "$rkw" \
    --arg replyTo "$MSG_ID" \
    '{recipients: ["wigy","karmi","admin"], sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  log "Sending review request: $rsubj"
  local resp
  resp=$(send_mail "$payload")

  # Extract the message ID from the response and mark as waiting for each admin
  local review_id
  review_id=$(echo "$resp" | jq -r '.id // empty')
  if [ -n "$review_id" ]; then
    for admin in wigy karmi admin; do
      set_status "$admin" "$review_id" '{"status":"waiting"}' || true
    done
    log "Review request sent ($review_id) and marked as waiting."
  else
    log "WARNING: Could not extract review message ID from response."
  fi
}

# ---------------------------------------------------------------------------
# Step 4: Dispatch based on topic
# ---------------------------------------------------------------------------

case "$TOPIC" in

  # =========================================================================
  card-request)
    log "Delegating to bin/handle-card-request..."
    "$SCRIPT_DIR/handle-card-request" "$MSG_ID" && RC=$? || RC=$?
    if [ "$RC" -eq 0 ]; then
      SUCCESS=true
    fi
    # handle-card-request manages its own reply mail, review request, and
    # status updates, so skip the generic reply/status steps below.
    DELEGATED=true
    REPLY_TOPIC=""
    ;;

  # =========================================================================
  certification-request)
    CARD_ID=$(echo "$KEYWORDS" | jq -r '.cardId // empty')
    USER_NAME=$(echo "$KEYWORDS" | jq -r '.userName // empty')

    if [ -z "$CARD_ID" ]; then
      fail "Missing cardId in message keywords."
    else
      log "Certification request: $CARD_ID (requested by $USER_NAME)"
      log "Dispatching topic \"certification-request\" to handler..."

      PROMPT=$(load_skill "handle-certify-card.md" "$CARD_ID")
      # Add explicit PR branch instruction
      PROMPT="$PROMPT

IMPORTANT: You MUST create a branch named certify-${CARD_ID}-<card-slug>, commit there, push, and open a PR. Do NOT commit to master."

      SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
      log "Handler completed (exit $RC)."

      # Extract PR URL
      PR_URL=$(echo "$SKILL_OUTPUT" | grep -oP 'https://github\.com/wigy/meccg/pull/[0-9]+' | tail -1 || true)
      GIT_HASH=$(echo "$SKILL_OUTPUT" | grep -oP '[0-9a-f]{40}' | tail -1 || true)
      CARD_NAME=$(echo "$SKILL_OUTPUT" | grep -oP '(?:Card|card)[:\s]+([A-Z][A-Za-z ]+)' | head -1 | sed 's/^[Cc]ard[: ]*//' || true)

      if echo "$SKILL_OUTPUT" | grep -qiP '(Playable:\s*YES|certification.*passed|certified|PR.*created|pull request)'; then
        SUCCESS=true
        REPLY_TOPIC="certification-reply"
        REPLY_SUBJECT="Certified: $CARD_ID"
        REPLY_BODY="Card **$CARD_ID** has been certified.

PR: $PR_URL"
        REPLY_KEYWORDS=$(jq -n \
          --arg origId "$MSG_ID" \
          --arg cardId "$CARD_ID" \
          --arg prUrl "$PR_URL" \
          --arg gitHash "$GIT_HASH" \
          '{originalMessageId: $origId, cardId: $cardId, prUrl: $prUrl, gitHash: $gitHash}')

        # Send review request
        REVIEW_KW=$(jq -n \
          --arg cardName "$CARD_NAME" \
          --arg cardId "$CARD_ID" \
          --arg gitHash "$GIT_HASH" \
          --arg prUrl "$PR_URL" \
          --arg userName "$USER_NAME" \
          '{cardName: $cardName, cardId: $cardId, gitHash: $gitHash, prUrl: $prUrl, userName: $userName}')
        send_review_request "review-request" "Review: $CARD_ID certified" \
          "Card **$CARD_ID** ($CARD_NAME) has been certified.

PR: $PR_URL" \
          "$REVIEW_KW"
      else
        fail "Certification handler did not indicate success. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
        REPLY_TOPIC="certification-reply"
        REPLY_SUBJECT="Certification failed: $CARD_ID"
      fi
    fi
    ;;

  # =========================================================================
  feature-planning-request)
    log "Dispatching topic \"feature-planning-request\" to handler..."

    PROMPT=$(load_skill "handle-planning-request.md" "$MSG_ID")
    SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
    log "Handler completed (exit $RC)."

    # The planning handler sends its own mail, so we just check success
    if echo "$SKILL_OUTPUT" | grep -qiP '(plan.*sent|success|processed)'; then
      SUCCESS=true
      # The skill already sends the reply mail; we skip sending another
      REPLY_TOPIC=""
    else
      fail "Planning handler did not indicate success. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
      REPLY_TOPIC="feature-planning-reply"
      REPLY_SUBJECT="Planning failed: $SUBJECT"
    fi
    ;;

  # =========================================================================
  feature-implementation-request)
    log "Dispatching topic \"feature-implementation-request\" to handler..."

    PROMPT=$(load_skill "handle-implementation-request.md" "$MSG_ID")
    SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
    log "Handler completed (exit $RC)."

    if echo "$SKILL_OUTPUT" | grep -qiP '(implemented|pushed|success|commit.*hash)'; then
      SUCCESS=true
      REPLY_TOPIC=""  # The skill sends its own review request
    else
      fail "Implementation handler did not indicate success. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
      REPLY_TOPIC="feature-reply"
      REPLY_SUBJECT="Implementation failed: $SUBJECT"
    fi
    ;;

  # =========================================================================
  bug-report)
    log "Dispatching topic \"bug-report\" to handler..."

    PROMPT=$(load_skill "handle-bug-report.md" "$MSG_ID")
    SKILL_OUTPUT=$(run_skill "$PROMPT") && RC=$? || RC=$?
    log "Handler completed (exit $RC)."

    if echo "$SKILL_OUTPUT" | grep -qiP '(fixed|pushed|success|commit.*hash)'; then
      SUCCESS=true
      REPLY_TOPIC=""  # The skill sends its own reply and review request
    else
      fail "Bug report handler did not indicate success. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
      REPLY_TOPIC="bug-reply"
      REPLY_SUBJECT="Unable to fix: $SUBJECT"
    fi
    ;;

  # =========================================================================
  feature-request|bug-fix-request)
    log "Topic \"$TOPIC\" cannot be automatically handled."
    fail "This type of request ($TOPIC) requires manual attention and cannot be processed automatically."
    REPLY_TOPIC="${TOPIC/request/reply}"
    REPLY_SUBJECT="Cannot auto-handle: $SUBJECT"
    ;;

  # =========================================================================
  *)
    log "Unknown or unsupported topic: $TOPIC"
    fail "Unknown or unsupported topic: $TOPIC. The message could not be processed."
    REPLY_TOPIC="error-reply"
    REPLY_SUBJECT="Unprocessable: $SUBJECT"
    ;;
esac

# ---------------------------------------------------------------------------
# Step 5: Send reply mail (if needed)
# ---------------------------------------------------------------------------

if [ -n "$REPLY_TOPIC" ]; then
  log "Sending reply to $RECIPIENT..."

  FROM_NAME=$(ai_display_name)

  # Build keywords — start with originalMessageId, merge any extras
  if [ -z "$REPLY_KEYWORDS" ] || [ "$REPLY_KEYWORDS" = "{}" ]; then
    REPLY_KEYWORDS=$(jq -n --arg origId "$MSG_ID" '{originalMessageId: $origId}')
  fi

  PAYLOAD=$(build_mail \
    --argjson recipients "[\"$RECIPIENT\"]" \
    --arg from "$FROM_NAME" \
    --arg topic "$REPLY_TOPIC" \
    --arg subject "$REPLY_SUBJECT" \
    --arg body "$REPLY_BODY" \
    --argjson keywords "$REPLY_KEYWORDS" \
    --arg replyTo "$MSG_ID" \
    '{recipients: $recipients, sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  send_mail "$PAYLOAD" >/dev/null
  log "Reply sent to $RECIPIENT."
fi

# ---------------------------------------------------------------------------
# Step 6: Mark as processed
# ---------------------------------------------------------------------------

if ! $DELEGATED; then
  if $SUCCESS; then
    log "Marking message as processed (success: true)"
    set_status "ai" "$MSG_ID" '{"status":"processed","success":true}'
  else
    log "Marking message as processed (success: false)"
    set_status "ai" "$MSG_ID" '{"status":"processed","success":false}'
  fi
fi

# ---------------------------------------------------------------------------
# Step 7: Report
# ---------------------------------------------------------------------------

echo ""
log "=== Summary ==="
log "Message:  $MSG_ID"
log "Topic:    $TOPIC"
log "Subject:  $SUBJECT"
log "From:     $FROM"
log "Success:  $SUCCESS"
if [ -n "$REPLY_TOPIC" ]; then
  log "Reply:    $REPLY_TOPIC -> $RECIPIENT"
fi
if [ -n "${SKILL_COST:-}" ]; then
  log "Cost:     \$${SKILL_COST}"
fi
if [ -n "${SKILL_DURATION_MS:-}" ]; then
  SUMMARY_SECS=$(( SKILL_DURATION_MS / 1000 ))
  SUMMARY_MINS=$(( SUMMARY_SECS / 60 ))
  SUMMARY_REM=$(( SUMMARY_SECS % 60 ))
  log "Duration: ${SUMMARY_MINS}m ${SUMMARY_REM}s"
fi
