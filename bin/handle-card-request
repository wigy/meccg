#!/usr/bin/env bash
# Handle a card request mail message by dispatching to the Claude skill,
# sending reply/review mail, and updating message status.
#
# Usage: handle-card-request <message-id>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SECRETS="$HOME/.meccg/secrets.json"
AI_INFO="$HOME/.meccg/players/ai/info.json"
BASE_URL="http://localhost:8080"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log() { echo "[handle-card-request] $*"; }

master_key() { jq -r .masterKey "$SECRETS"; }

ai_display_name() { jq -r .displayName "$AI_INFO"; }

login_ai() {
  local key
  key=$(master_key)
  curl -s -c - -X POST "$BASE_URL/api/login" \
    -H 'Content-Type: application/json' \
    -d "{\"name\":\"ai\",\"password\":\"$key\"}" \
    | grep meccg-session | awk '{print $NF}'
}

api_get() {
  curl -s "$BASE_URL$1" -b "meccg-session=$SESSION"
}

api_post() {
  curl -s -X POST "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

api_put() {
  curl -s -X PUT "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

set_status() {
  api_put "/api/system/mail/$1/$2" "$3"
}

send_mail() {
  api_post "/api/system/mail" "$1"
}

build_mail() {
  jq -n "$@"
}

run_add_card() {
  cd "$PROJECT_DIR"
  node bin/add-card.mjs "$@" 2>&1
}

send_review_request() {
  local rtopic="$1" rsubj="$2" rbody="$3" rkw="$4"
  local from_name
  from_name=$(ai_display_name)

  local payload
  payload=$(build_mail \
    --arg from "$from_name" \
    --arg topic "$rtopic" \
    --arg subject "$rsubj" \
    --arg body "$rbody" \
    --argjson keywords "$rkw" \
    --arg replyTo "$MSG_ID" \
    '{recipients: ["wigy","karmi","admin"], sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  log "Sending review request: $rsubj"
  local resp
  resp=$(send_mail "$payload")

  local review_id
  review_id=$(echo "$resp" | jq -r '.id // empty')
  if [ -n "$review_id" ]; then
    for admin in wigy karmi admin; do
      set_status "$admin" "$review_id" '{"status":"waiting"}' || true
    done
    log "Review request sent ($review_id) and marked as waiting."
  else
    log "WARNING: Could not extract review message ID from response."
  fi
}

# ---------------------------------------------------------------------------
# Validate arguments
# ---------------------------------------------------------------------------

if [ $# -eq 0 ] || [ -z "${1:-}" ]; then
  echo "Usage: handle-card-request <message-id>" >&2
  exit 1
fi

MSG_ID="$1"

# ---------------------------------------------------------------------------
# Step 1: Log in
# ---------------------------------------------------------------------------

log "Logging in as ai..."
SESSION=$(login_ai)
if [ -z "$SESSION" ]; then
  log "ERROR: Failed to log in as ai"
  exit 1
fi
log "Logged in."

# ---------------------------------------------------------------------------
# Step 2: Fetch the message
# ---------------------------------------------------------------------------

log "Fetching message $MSG_ID..."
MSG=$(api_get "/api/mail/inbox/$MSG_ID")

if echo "$MSG" | jq -e '.error' &>/dev/null; then
  log "ERROR: Message not found: $(echo "$MSG" | jq -r '.error')"
  exit 1
fi

TOPIC=$(echo "$MSG" | jq -r '.topic // empty')
SUBJECT=$(echo "$MSG" | jq -r '.subject // empty')
FROM=$(echo "$MSG" | jq -r '.from // empty')
SENDER=$(echo "$MSG" | jq -r '.sender // empty')
KEYWORDS=$(echo "$MSG" | jq -c '.keywords // {}')

if [ "$TOPIC" != "card-request" ]; then
  log "ERROR: Message topic is \"$TOPIC\", expected \"card-request\""
  exit 1
fi

log "Message $MSG_ID: \"$SUBJECT\" from $FROM (topic: $TOPIC)"

# ---------------------------------------------------------------------------
# Step 3: Mark as processing
# ---------------------------------------------------------------------------

log "Marking as processing..."
set_status "ai" "$MSG_ID" '{"status":"processing"}'

# ---------------------------------------------------------------------------
# Step 4: Extract keywords and dispatch
# ---------------------------------------------------------------------------

CARD_NAME=$(echo "$KEYWORDS" | jq -r '.cardName // empty')
DECK_ID=$(echo "$KEYWORDS" | jq -r '.deckId // empty')
USER_NAME=$(echo "$KEYWORDS" | jq -r '.userName // empty')

RECIPIENT=$(echo "$KEYWORDS" | jq -r '.userName // empty')
if [ -z "$RECIPIENT" ]; then
  RECIPIENT="$SENDER"
fi

SUCCESS=false
REPLY_TOPIC=""
REPLY_SUBJECT=""
REPLY_BODY=""
REPLY_KEYWORDS="{}"

if [ -z "$CARD_NAME" ] || [ -z "$DECK_ID" ]; then
  REPLY_TOPIC="card-reply"
  REPLY_SUBJECT="Failed to add: $SUBJECT"
  REPLY_BODY="Missing cardName or deckId in message keywords."
  log "ERROR: Missing cardName or deckId in message keywords."
else
  log "Card request: $CARD_NAME for deck $DECK_ID (requested by $USER_NAME)"
  log "Dispatching to add-card script..."

  SKILL_OUTPUT=$(run_add_card "$CARD_NAME" "$DECK_ID") && RC=$? || RC=$?
  log "Handler completed (exit $RC)."

  # Try to extract git hash from the output
  GIT_HASH=$(echo "$SKILL_OUTPUT" | grep -oP '(?<=commit hash[:\s]*)[0-9a-f]{7,40}' | tail -1 || true)
  if [ -z "$GIT_HASH" ]; then
    GIT_HASH=$(echo "$SKILL_OUTPUT" | grep -oP '[0-9a-f]{40}' | tail -1 || true)
  fi
  if [ -z "$GIT_HASH" ]; then
    GIT_HASH=$(cd "$PROJECT_DIR" && git rev-parse HEAD)
  fi

  # Check for success indicators in the output
  if echo "$SKILL_OUTPUT" | grep -qiP '(successfully added|card.*added|commit.*push|pushed)'; then
    SUCCESS=true
    REPLY_TOPIC="card-reply"
    REPLY_SUBJECT="Added: $CARD_NAME"

    # Try to find the card image from data files
    CARD_ID=$(echo "$SKILL_OUTPUT" | grep -oP '(?:card.?id|definition.?id)[:\s]*"?([a-z]+-[0-9]+)"?' | grep -oP '[a-z]+-[0-9]+' | head -1 || true)
    IMAGE_MD=""
    if [ -n "$CARD_ID" ]; then
      SET_PREFIX="${CARD_ID%%-*}"
      IMAGE_FILE=$(cd "$PROJECT_DIR" && grep -r "\"$CARD_ID\"" packages/shared/src/data/ 2>/dev/null \
        | head -1 | grep -oP '"image":\s*"[^"]*"' | grep -oP 'https?://[^"]+' || true)
      if [ -n "$IMAGE_FILE" ]; then
        IMG_FILENAME=$(basename "$IMAGE_FILE")
        IMAGE_MD="![${CARD_NAME}](/cards/images/${SET_PREFIX}/${IMG_FILENAME})"
      fi
    fi

    REPLY_BODY="$IMAGE_MD

The card **$CARD_NAME** ($CARD_ID) has been added to the card pool.

Commit: https://github.com/wigy/meccg/commit/$GIT_HASH"

    REPLY_KEYWORDS=$(jq -n \
      --arg origId "$MSG_ID" \
      --arg cardName "$CARD_NAME" \
      --arg cardId "$CARD_ID" \
      --arg gitHash "$GIT_HASH" \
      '{originalMessageId: $origId, cardName: $cardName, cardId: $cardId, gitHash: $gitHash}')

    # Send review request
    REVIEW_KW=$(jq -n \
      --arg cardName "$CARD_NAME" \
      --arg cardId "$CARD_ID" \
      --arg gitHash "$GIT_HASH" \
      --arg userName "$USER_NAME" \
      '{cardName: $cardName, cardId: $cardId, gitHash: $gitHash, userName: $userName}')
    send_review_request "review-request" "Review: $CARD_NAME added" \
      "${IMAGE_MD}

**$CARD_NAME** ($CARD_ID) was added from a card request by $USER_NAME.

Commit: https://github.com/wigy/meccg/commit/$GIT_HASH" \
      "$REVIEW_KW"
  else
    REPLY_TOPIC="card-reply"
    REPLY_SUBJECT="Failed to add: $CARD_NAME"
    REPLY_BODY="Card request handler did not indicate success. Output tail:
$(echo "$SKILL_OUTPUT" | tail -20)"
    log "Handler failed."
  fi
fi

# ---------------------------------------------------------------------------
# Step 5: Send reply mail
# ---------------------------------------------------------------------------

if [ -n "$REPLY_TOPIC" ]; then
  log "Sending reply to $RECIPIENT..."

  FROM_NAME=$(ai_display_name)

  if [ -z "$REPLY_KEYWORDS" ] || [ "$REPLY_KEYWORDS" = "{}" ]; then
    REPLY_KEYWORDS=$(jq -n --arg origId "$MSG_ID" '{originalMessageId: $origId}')
  fi

  PAYLOAD=$(build_mail \
    --argjson recipients "[\"$RECIPIENT\"]" \
    --arg from "$FROM_NAME" \
    --arg topic "$REPLY_TOPIC" \
    --arg subject "$REPLY_SUBJECT" \
    --arg body "$REPLY_BODY" \
    --argjson keywords "$REPLY_KEYWORDS" \
    --arg replyTo "$MSG_ID" \
    '{recipients: $recipients, sender: "ai", from: $from,
      topic: $topic, subject: $subject, body: $body,
      keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

  send_mail "$PAYLOAD" >/dev/null
  log "Reply sent to $RECIPIENT."
fi

# ---------------------------------------------------------------------------
# Step 6: Mark as processed
# ---------------------------------------------------------------------------

if $SUCCESS; then
  log "Marking message as processed (success: true)"
  set_status "ai" "$MSG_ID" '{"status":"processed","success":true}'
else
  log "Marking message as processed (success: false)"
  set_status "ai" "$MSG_ID" '{"status":"processed","success":false}'
fi

# ---------------------------------------------------------------------------
# Step 7: Report
# ---------------------------------------------------------------------------

echo ""
log "=== Summary ==="
log "Message:  $MSG_ID"
log "Subject:  $SUBJECT"
log "From:     $FROM"
log "Card:     $CARD_NAME"
log "Deck:     $DECK_ID"
log "Success:  $SUCCESS"
if [ -n "$REPLY_TOPIC" ]; then
  log "Reply:    $REPLY_TOPIC -> $RECIPIENT"
fi
