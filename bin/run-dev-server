#!/bin/bash

set -e

FILE=`readlink -f "${BASH_SOURCE[0]}"`
ROOT=`dirname "$FILE"`/..

cd "$ROOT"

# Build web-client bundle once up front
npm run build -w @meccg/web-client

# Start esbuild watcher for web-client in background
npx esbuild packages/web-client/src/browser/app.ts \
  --bundle --outfile=packages/web-client/public/bundle.js \
  --format=iife --platform=browser --watch=forever &
ESBUILD_PID=$!

# Clean up esbuild watcher on exit
trap "kill $ESBUILD_PID 2>/dev/null" EXIT

# Start lobby server (nodemon watches public/ for reload signals)
npm run dev -w @meccg/lobby-server
