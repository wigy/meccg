#!/bin/bash

set -e

FILE=`readlink -f "${BASH_SOURCE[0]}"`
ROOT=`dirname "$FILE"`/..

cd "$ROOT"

# Build browser bundle once up front
npm run build:browser -w @meccg/lobby-server

# Start esbuild watcher for browser code in background
npx esbuild packages/lobby-server/src/browser/app.ts \
  --bundle --outfile=packages/lobby-server/public/bundle.js \
  --format=iife --platform=browser --watch=forever &
ESBUILD_PID=$!

# Clean up esbuild watcher on exit
trap "kill $ESBUILD_PID 2>/dev/null" EXIT

# Start lobby server (nodemon watches public/ for reload signals)
npm run dev -w @meccg/lobby-server
