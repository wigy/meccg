#!/usr/bin/env bash
# List unhandled requests in the ai and admin inboxes
# (status: new, topic: *-request or bug-report).
#
# Feature-requests go to the admin inbox; everything else (certification,
# card, planning, implementation, bug-report) goes to the ai inbox. Both
# are scanned so all unhandled requests appear in one place.
set -euo pipefail

INBOX_DIRS=(
  "$HOME/.meccg/players/ai/mail/inbox"
  "$HOME/.meccg/players/admin/mail/inbox"
)

shopt -s nullglob
files=()
for dir in "${INBOX_DIRS[@]}"; do
  [ -d "$dir" ] || continue
  files+=("$dir"/*.json)
done
shopt -u nullglob

if [ ${#files[@]} -eq 0 ]; then
  echo "No messages in inbox."
  exit 0
fi

# Filter to unhandled requests (status=new, topic ends with -request, or bug-report)
# Output: timestamp | id | topic | subject
jq -r 'select(.status == "new" and ((.topic | endswith("-request")) or .topic == "bug-report")) |
  [.timestamp, .id, .topic, .subject] | @tsv' "${files[@]}" |
  sort |
  while IFS=$'\t' read -r ts id topic subject; do
    printf "%-20s  %-18s  %-25s  %s\n" "$ts" "$id" "$topic" "$subject"
  done
