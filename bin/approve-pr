#!/usr/bin/env bash
# Approve a PR produced by an automated handler (bug fix, feature
# implementation, card certification, review-fix).
#
# Flow:
#   1. Resolve the PR URL (from number or URL).
#   2. Look up the matching review-request in ai's sent mail by keywords.prUrl,
#      recover the stashed pendingReplyJson (the reply handle-mail withheld).
#   3. Check out the PR branch, bump the patch version in all four workspace
#      package.json files, commit, push.
#   4. Merge the PR with --merge.
#   5. Send the withheld reply to the original requestor, appending the
#      version number where the fix ships. This is the first and only
#      requestor-visible mail for the entire processing cycle.
#
# Usage: approve-pr <pr-number-or-url>
set -euo pipefail

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
if [ $# -ge 1 ] && { [ "$1" = "-h" ] || [ "$1" = "--help" ]; }; then
  cat <<'EOF'
Usage: approve-pr <pr-number-or-url>

Bumps the patch version across all workspace packages, pushes that commit
to the PR branch, merges the PR, and sends the previously-withheld reply
to the original requestor with the version number where the fix ships.

Arguments:
  <pr-number-or-url>    PR number (e.g. 42) or full URL
                        (e.g. https://github.com/wigy/meccg/pull/42)

Options:
  -h, --help            Show this help message.
EOF
  exit 0
fi

if [ $# -lt 1 ] || [ -z "${1:-}" ]; then
  echo "Usage: approve-pr <pr-number-or-url>" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
AI_SENT_DIR="$HOME/.meccg/players/ai/mail/sent"
SECRETS="$HOME/.meccg/secrets.json"
AI_INFO="$HOME/.meccg/players/ai/info.json"
BASE_URL="http://localhost:8080"
REPO_SLUG="wigy/meccg"

log() { echo "[approve-pr] $*"; }

master_key() { jq -r .masterKey "$SECRETS"; }
ai_display_name() { jq -r .displayName "$AI_INFO"; }

api_post() {
  curl -s -X POST "$BASE_URL$1" \
    -H "Authorization: Bearer $(master_key)" \
    -H 'Content-Type: application/json' \
    -d "$2"
}

# ---------------------------------------------------------------------------
# Step 1: Resolve PR URL
# ---------------------------------------------------------------------------
ARG="$1"
case "$ARG" in
  https://github.com/*/pull/*)
    PR_URL="${ARG%/}"
    ;;
  ''|*[!0-9]*)
    echo "Invalid PR reference: $ARG (expected number or URL)" >&2
    exit 1
    ;;
  *)
    PR_URL="https://github.com/${REPO_SLUG}/pull/${ARG}"
    ;;
esac
log "PR: $PR_URL"

cd "$PROJECT_DIR"

# ---------------------------------------------------------------------------
# Step 2: Look up PR info
# ---------------------------------------------------------------------------
PR_JSON=$(gh pr view "$PR_URL" --json state,headRefName,title,number 2>&1 || true)
if ! echo "$PR_JSON" | jq -e . >/dev/null 2>&1; then
  log "ERROR: Failed to fetch PR info: $PR_JSON"
  exit 1
fi
PR_STATE=$(echo "$PR_JSON" | jq -r .state)
PR_BRANCH=$(echo "$PR_JSON" | jq -r .headRefName)
PR_TITLE=$(echo "$PR_JSON" | jq -r .title)
log "State: $PR_STATE  Branch: $PR_BRANCH  Title: $PR_TITLE"

# ---------------------------------------------------------------------------
# Step 3: Find the matching review-request in ai's sent folder
# ---------------------------------------------------------------------------
log "Searching ai sent mail for review-request with prUrl=$PR_URL..."
REVIEW_FILE=""
BEST_TS=""
if [ -d "$AI_SENT_DIR" ]; then
  for f in "$AI_SENT_DIR"/*.json; do
    [ -f "$f" ] || continue
    topic=$(jq -r '.topic // empty' "$f" 2>/dev/null || echo "")
    [ "$topic" = "review-request" ] || continue
    prurl=$(jq -r '.keywords.prUrl // empty' "$f" 2>/dev/null || echo "")
    [ "$prurl" = "$PR_URL" ] || continue
    ts=$(jq -r '.timestamp // empty' "$f" 2>/dev/null || echo "")
    if [ -z "$BEST_TS" ] || [[ "$ts" > "$BEST_TS" ]]; then
      BEST_TS="$ts"
      REVIEW_FILE="$f"
    fi
  done
fi

PENDING_REPLY=""
if [ -n "$REVIEW_FILE" ]; then
  log "Matched review-request: $(basename "$REVIEW_FILE") ($BEST_TS)"
  PENDING_REPLY=$(jq -r '.keywords.pendingReplyJson // empty' "$REVIEW_FILE")
  if [ -z "$PENDING_REPLY" ]; then
    log "WARNING: review-request has no pendingReplyJson — no reply will be sent."
  fi
else
  log "WARNING: no review-request found for $PR_URL — no reply will be sent."
fi

# ---------------------------------------------------------------------------
# Step 4: Bump version, push, merge (only if PR is still open)
# ---------------------------------------------------------------------------
NEW_VERSION=""
if [ "$PR_STATE" = "OPEN" ]; then
  log "Fetching branch $PR_BRANCH..."
  git fetch origin "$PR_BRANCH":"$PR_BRANCH" 2>/dev/null || git fetch origin "$PR_BRANCH"
  git checkout "$PR_BRANCH"
  git pull --ff-only origin "$PR_BRANCH"

  CURRENT_VERSION=$(jq -r .version packages/shared/package.json)
  log "Current version: $CURRENT_VERSION"

  MAJOR="${CURRENT_VERSION%%.*}"
  REST="${CURRENT_VERSION#*.}"
  MINOR="${REST%%.*}"
  PATCH="${REST#*.}"
  # Strip any prerelease suffix from patch (e.g. 1.2.3-alpha -> 3)
  PATCH="${PATCH%%-*}"
  NEW_PATCH=$((PATCH + 1))
  NEW_VERSION="${MAJOR}.${MINOR}.${NEW_PATCH}"
  log "New version: $NEW_VERSION"

  for pkg in packages/shared packages/game-server packages/text-client packages/lobby-server; do
    tmp=$(mktemp)
    jq --arg v "$NEW_VERSION" '.version = $v' "$pkg/package.json" > "$tmp"
    mv "$tmp" "$pkg/package.json"
  done

  git add \
    packages/shared/package.json \
    packages/game-server/package.json \
    packages/text-client/package.json \
    packages/lobby-server/package.json
  git commit -m "$(cat <<EOF
Bump version to $NEW_VERSION

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
EOF
)"
  git push origin "$PR_BRANCH"

  log "Merging PR..."
  gh pr merge "$PR_URL" --merge
  git checkout master
  git pull --ff-only
else
  log "PR already in state $PR_STATE — skipping version bump and merge."
  git checkout master 2>/dev/null || true
  git pull --ff-only 2>/dev/null || true
  NEW_VERSION=$(jq -r .version packages/shared/package.json)
fi

# ---------------------------------------------------------------------------
# Step 5: Send the withheld reply, with version info
# ---------------------------------------------------------------------------
if [ -n "$PENDING_REPLY" ]; then
  RECIPIENT=$(echo "$PENDING_REPLY" | jq -r '.recipient // empty')
  REPLY_TOPIC=$(echo "$PENDING_REPLY" | jq -r '.topic // empty')
  REPLY_SUBJECT=$(echo "$PENDING_REPLY" | jq -r '.subject // empty')
  REPLY_BODY=$(echo "$PENDING_REPLY" | jq -r '.body // empty')
  REPLY_KEYWORDS=$(echo "$PENDING_REPLY" | jq -c '.keywords // {}')
  REPLY_TO=$(echo "$PENDING_REPLY" | jq -r '.replyTo // empty')

  if [ -z "$RECIPIENT" ] || [ -z "$REPLY_TOPIC" ]; then
    log "ERROR: stashed reply is missing recipient or topic — skipping."
  else
    VERSION_NOTE="

---
*Merged and shipping in v${NEW_VERSION}.*"
    REPLY_BODY="${REPLY_BODY}${VERSION_NOTE}"

    REPLY_KEYWORDS=$(echo "$REPLY_KEYWORDS" | jq --arg v "$NEW_VERSION" '. + {version: $v}')

    FROM_NAME=$(ai_display_name)
    PAYLOAD=$(jq -n \
      --argjson recipients "[\"$RECIPIENT\"]" \
      --arg from "$FROM_NAME" \
      --arg topic "$REPLY_TOPIC" \
      --arg subject "$REPLY_SUBJECT" \
      --arg body "$REPLY_BODY" \
      --argjson keywords "$REPLY_KEYWORDS" \
      --arg replyTo "$REPLY_TO" \
      '{recipients: $recipients, sender: "ai", from: $from,
        topic: $topic, subject: $subject, body: $body,
        keywords: $keywords, replyTo: $replyTo, sentBy: "ai"}')

    log "Sending reply to $RECIPIENT (topic=$REPLY_TOPIC)..."
    api_post "/api/system/mail" "$PAYLOAD" >/dev/null
    log "Reply sent."
  fi
fi

log "Done. Version: $NEW_VERSION"
